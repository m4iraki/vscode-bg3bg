{
	"name": "vscode-bg3bg",
	"displayName": "BG3BG VSCode",
	"description": "Baldur's Gate 3 Banks Helper for VSCode",
	"version": "0.1.0",
	"publisher": "m4iraki",
	"_repository": "",
	"engines": {
		"vscode": "^1.100.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "bg3bg.generateUUID",
				"title": "Generate UUID"
			},
			{
				"command": "bg3bg.generateHandle",
				"title": "Generate Handle"
			},
			{
				"command": "bg3bg.regenerateSelected",
				"title": "Regenerate Selected Id"
			},
			{
				"command": "bg3bg.regenerateAllIds",
				"title": "Regenerate All Ids"
			},
			{
				"command": "bg3bg.toolkitify",
				"title": "Toolkitify"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "bg3bg",
					"title": "BG3 Banks Helper",
					"icon": "resources/bhaal-logo2.png"
				}
			]
		},
		"views": {
			"bg3bg": [
				{
					"id": "bg3bg.main",
					"name": "Helpers",
					"icon": "$()"
				},
				{
					"id": "bg3bg.explorer",
					"name": "Entities",
					"icon": "$()"
				}
			]
		},
		"configuration": {
			"title": "BG3 Banks Helper",
			"properties": {
				"bg3bg.divineexe": {
					"type": "string",
					"default": "",
					"description": "Path to LSLib divine.exe",
					"scope": "machine-overridable"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint",
		"watch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/node": "^22",
		"@types/sax": "^1.2.7",
		"@types/uuid": "^10.0.0",
		"@types/vscode": "^1.100.0",
		"eslint": "^9.13.0",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.26.0"
	},
	"dependencies": {
		"sax": "^1.6.0",
		"uuid": "^13.0.0"
	}
}