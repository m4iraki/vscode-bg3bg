{
	"name": "vscode-bg3bg",
	"displayName": "BG3BG VSCode",
	"description": "Baldur's Gate 3 Banks Helper for VSCode",
	"version": "0.3.1",
	"publisher": "m4iraki",
	"repository": "github:m4iraki/vscode-bg3bg",
	"icon": "resources/bhaal-logo2.png",
	"keywords": [
		"bg3",
		"baldurs gate 3",
		"localization",
		"lsx",
		"modding"
	],
	"engines": {
		"vscode": "^1.100.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onLanguage:xml",
		"onLanguage:plaintext"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "bg3bg.generateUUID",
				"title": "Generate UUID"
			},
			{
				"command": "bg3bg.generateHandle",
				"title": "Generate Handle"
			},
			{
				"command": "bg3bg.regenerateSelected",
				"title": "Regenerate Selected Id"
			},
			{
				"command": "bg3bg.regenerateAllIds",
				"title": "Regenerate All Ids"
			},
			{
				"command": "bg3bg.toolkitify",
				"title": "Toolkitify",
				"icon": "$(archive)"
			},
			{
				"command": "bg3bg.removeToolkitProj",
				"title": "Remove Toolkit Project",
				"icon": "$(unarchive)"
			},
			{
				"command": "bg3bg.refreshEntities",
				"title": "Refresh Entities",
				"icon": "$(refresh)"
			},
			{
				"command": "bg3bg.refreshLoca",
				"title": "Refresh Localization",
				"icon": "$(refresh)"
			},
			{
				"command": "bg3bg.createPackage",
				"title": "Create PAK",
				"icon": "$(file-zip)"
			},
			{
				"command": "bg3bg.openBrazilianPortuguese",
				"title": "PT"
			},
			{
				"command": "bg3bg.openChinese",
				"title": "ZH"
			},
			{
				"command": "bg3bg.openChineseTraditional",
				"title": "ZH"
			},
			{
				"command": "bg3bg.openEnglish",
				"title": "EN"
			},
			{
				"command": "bg3bg.openFrench",
				"title": "FR"
			},
			{
				"command": "bg3bg.openGerman",
				"title": "DE"
			},
			{
				"command": "bg3bg.openItalian",
				"title": "IT"
			},
			{
				"command": "bg3bg.openJapanese",
				"title": "JA"
			},
			{
				"command": "bg3bg.openKorean",
				"title": "KR"
			},
			{
				"command": "bg3bg.openLatinSpanish",
				"title": "LA"
			},
			{
				"command": "bg3bg.openPolish",
				"title": "PL"
			},
			{
				"command": "bg3bg.openRussian",
				"title": "RU"
			},
			{
				"command": "bg3bg.openSpanish",
				"title": "ES"
			},
			{
				"command": "bg3bg.openTurkish",
				"title": "TR"
			},
			{
				"command": "bg3bg.openUkrainian",
				"title": "UK"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "bg3bg",
					"title": "BG3 Banks Helper",
					"icon": "resources/bhaal-logo2.png"
				}
			]
		},
		"views": {
			"bg3bg": [
				{
					"id": "bg3bg.helpers",
					"name": "Helpers",
					"icon": "$(wand)"
				},
				{
					"id": "bg3bg.entExplorer",
					"name": "Entities",
					"icon": "$(symbol-misc)"
				},
				{
					"id": "bg3bg.locaExplorer",
					"name": "Localization",
					"icon": "$(globe)"
				}
			]
		},
		"menus": {
			"view/title": [
				{
					"command": "bg3bg.refreshEntities",
					"when": "view == bg3bg.entExplorer",
					"group": "navigation"
				},
				{
					"command": "bg3bg.refreshLoca",
					"when": "view == bg3bg.locaExplorer",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "bg3bg.openBrazilianPortuguese",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /BrazilianPortuguese/",
					"group": "inline"
				},
				{
					"command": "bg3bg.openChinese",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /Chinese/",
					"group": "inline"
				},
				{
					"command": "bg3bg.openChineseTraditional",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /ChineseTraditional/",
					"group": "inline"
				},
				{
					"command": "bg3bg.openEnglish",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /English/",
					"group": "inline"
				},
				{
					"command": "bg3bg.openFrench",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /French/",
					"group": "inline"
				},
				{
					"command": "bg3bg.openGerman",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /German/",
					"group": "inline"
				},
				{
					"command": "bg3bg.openItalian",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /Italian/",
					"group": "inline"
				},
				{
					"command": "bg3bg.openJapanese",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /Japanese/",
					"group": "inline"
				},
				{
					"command": "bg3bg.openKorean",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /Korean/",
					"group": "inline"
				},
				{
					"command": "bg3bg.openLatinSpanish",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /LatinSpanish/",
					"group": "inline"
				},
				{
					"command": "bg3bg.openPolish",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /Polish/",
					"group": "inline"
				},
				{
					"command": "bg3bg.openRussian",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /Russian/",
					"group": "inline"
				},
				{
					"command": "bg3bg.openSpanish",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /Spanish/",
					"group": "inline"
				},
				{
					"command": "bg3bg.openTurkish",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /Turkish/",
					"group": "inline"
				},
				{
					"command": "bg3bg.openUkrainian",
					"when": "view == bg3bg.locaExplorer && viewItem =~ /Ukrainian/",
					"group": "inline"
				}
			]
		},
		"configuration": {
			"title": "BG3 Banks Helper",
			"properties": {
				"bg3bg.divineexe": {
					"type": "string",
					"default": "",
					"description": "Path to LSLib divine.exe",
					"scope": "machine-overridable"
				},
				"bg3bg.gamedata": {
					"type": "string",
					"default": "",
					"description": "Path to game's 'Data' Folder",
					"scope": "machine-overridable"
				}
			}
		},
		"languages": [
			{
				"id": "lsx",
				"extensions": [
					".lsx"
				],
				"aliases": [
					"Larian Studios XML",
					"lsx",
					"LS XML"
				],
				"mimetypes": [
					"text/xml",
					"application/xml"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "lsx",
				"scopeName": "text.xml.lsx",
				"path": "./syntaxes/lsx.tmLanguage.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint",
		"watch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/node": "^22",
		"@types/sax": "^1.2.7",
		"@types/uuid": "^10.0.0",
		"@types/vscode": "^1.100.0",
		"eslint": "^9.13.0",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.26.0"
	},
	"dependencies": {
		"fflate": "^0.8.2",
		"sax": "^1.6.0",
		"uuid": "^13.0.0"
	}
}
